{
  "datasets": [
    {
      "name": "d50d7ff9",
      "displayName": "Kpis",
      "queryLines": [
        "SELECT\n",
        "  MAX(Continent) AS Continent,\n",
        "  SUM(population_2022) AS world_total_population,\n",
        "  MAX_BY(country, population_2022) AS most_populous_country,\n",
        "  AVG(density_km2) AS avg_population_density,\n",
        "  COUNT(DISTINCT country) AS country_count\n",
        "FROM dbr_dev.yanquiel.gld_population\n",
        "WHERE (:continent_filter = 'All' OR Continent = :continent_filter)"
      ],
      "parameters": [
        {
          "displayName": "continent_filter",
          "keyword": "continent_filter",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "All"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "229beab8",
      "displayName": "country_detail",
      "queryLines": [
        "SELECT country, Continent, capital, region, population_2022, density_km2\n",
        "FROM dbr_dev.yanquiel.gld_population\n",
        "WHERE (:continent_filter = 'All' OR Continent = :continent_filter)\n",
        "ORDER BY population_2022 DESC"
      ],
      "parameters": [
        {
          "displayName": "continent_filter",
          "keyword": "continent_filter",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "All"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3a411f8c",
      "displayName": "by_continent",
      "queryLines": [
        "SELECT DISTINCT Continent, continent_total_population, continent_num_countries\n",
        "FROM dbr_dev.yanquiel.gld_population\n",
        "WHERE (:continent_filter = 'All' OR Continent = :continent_filter)"
      ],
      "parameters": [
        {
          "displayName": "continent_filter",
          "keyword": "continent_filter",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "All"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "top_10_countries",
      "displayName": "Top 10 Countries",
      "queryLines": [
        "SELECT\n",
        "  country,\n",
        "  Continent,\n",
        "  capital,\n",
        "  region,\n",
        "  population_2022\n",
        "FROM\n",
        "  dbr_dev.yanquiel.gld_population\n",
        "WHERE\n",
        "  (\n",
        "    :continent_filter = 'All'\n",
        "    OR Continent = :continent_filter\n",
        "  )\n",
        "ORDER BY\n",
        "  population_2022 DESC\n",
        "LIMIT 10"
      ],
      "parameters": [
        {
          "displayName": "Continent",
          "keyword": "continent_filter",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "All"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "continent_filter_options",
      "displayName": "Continent Filter Options",
      "queryLines": [
        "SELECT\n",
        "  'All' AS Continent\n",
        "UNION ALL\n",
        "SELECT DISTINCT\n",
        "  Continent\n",
        "FROM\n",
        "  dbr_dev.yanquiel.gld_population\n",
        "WHERE\n",
        "  Continent IS NOT NULL\n",
        "ORDER BY\n",
        "  CASE\n",
        "    WHEN Continent = 'All' THEN 0\n",
        "    ELSE 1\n",
        "  END,\n",
        "  Continent"
      ]
    }
  ],
