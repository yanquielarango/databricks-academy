{
  "datasets": [
    {
      "name": "b2096016",
      "displayName": "global_population_counts_by_Continent_overview",
      "queryLines": [
        "SELECT Continent, total_population\n",
        "FROM dbr_dev.yanquiel.gld_population_by_continent\n",
        "ORDER BY total_population DESC"
      ]
    },
    {
      "name": "2da4c2dd",
      "displayName": "top_10_most_populated_countries",
      "queryLines": [
        "SELECT country, Continent, population_2022, capital, currency_code\n",
        "FROM dbr_dev.yanquiel.gld_population_enriched\n",
        "ORDER BY population_2022 DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "world_population_map",
      "displayName": "World population by country",
      "queryLines": [
        "SELECT\n",
        "  country,\n",
        "  Continent,\n",
        "  population_2022\n",
        "FROM\n",
        "  gld_population_enriched"
      ],
      "catalog": "dbr_dev",
      "schema": "yanquiel"
    },
    {
      "name": "population_kpis",
      "displayName": "Population KPIs",
      "queryLines": [
        "SELECT\n",
        "  Continent,\n",
        "  total_population,\n",
        "  num_countries,\n",
        "  avg_growth_rate\n",
        "FROM\n",
        "  gld_population_by_continent"
      ],
      "catalog": "dbr_dev",
      "schema": "yanquiel"
    },
    {
      "name": "world_population_trend",
      "displayName": "World population trend",
      "queryLines": [
        "SELECT\n",
        "  Continent,\n",
        "  CAST(year AS INT) AS year,\n",
        "  SUM(population) AS total_population\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      Continent,\n",
        "      1970 AS year,\n",
        "      `1970_Population` AS population\n",
        "    FROM\n",
        "      brz_world_population\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      Continent,\n",
        "      1980 AS year,\n",
        "      `1980_Population` AS population\n",
        "    FROM\n",
        "      brz_world_population\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      Continent,\n",
        "      1990 AS year,\n",
        "      `1990_Population` AS population\n",
        "    FROM\n",
        "      brz_world_population\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      Continent,\n",
        "      2000 AS year,\n",
        "      `2000_Population` AS population\n",
        "    FROM\n",
        "      brz_world_population\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      Continent,\n",
        "      2010 AS year,\n",
        "      `2010_Population` AS population\n",
        "    FROM\n",
        "      brz_world_population\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      Continent,\n",
        "      2015 AS year,\n",
        "      `2015_Population` AS population\n",
        "    FROM\n",
        "      brz_world_population\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      Continent,\n",
        "      2020 AS year,\n",
        "      `2020_Population` AS population\n",
        "    FROM\n",
        "      brz_world_population\n",
        "    UNION ALL\n",
        "    SELECT\n",
        "      Continent,\n",
        "      2022 AS year,\n",
        "      `2022_Population` AS population\n",
        "    FROM\n",
        "      brz_world_population\n",
        "  ) t\n",
        "GROUP BY\n",
        "  Continent,\n",
        "  year\n",
        "ORDER BY\n",
        "  year,\n",
        "  Continent"
      ],
      "catalog": "dbr_dev",
      "schema": "yanquiel"
    },
    {
      "name": "most_populous_country",
      "displayName": "Most populous country",
      "queryLines": [
        "SELECT\n",
        "  country,\n",
        "  Continent,\n",
        "  population_2022\n",
        "FROM\n",
        "  gld_population_enriched\n",
        "ORDER BY\n",
        "  population_2022 DESC\n",
        "LIMIT 1"
      ],
      "catalog": "dbr_dev",
      "schema": "yanquiel"
    }
  ],
